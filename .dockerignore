.git/
.gitignore
.vscode/
.idea/
.DS_Store

# Docs
README.md
*.md

# Prompt logs (dev-time artifact)
prompt_logs/

# Frontend (has its own Dockerfile, not needed in backend image)
frontend/

# Docker files themselves
Dockerfile
docker-compose.yml
