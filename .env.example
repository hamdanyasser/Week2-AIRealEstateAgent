# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# API key for the LLM provider.
#   - OpenAI:  https://platform.openai.com/api-keys
#   - Groq (free tier, OpenAI-compatible):  https://console.groq.com/keys
OPENAI_API_KEY=your-key-here

# Optional: point at any OpenAI-compatible provider. Leave blank for OpenAI.
# Groq example:
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_BASE_URL=

# Chat model name. Must match the provider above.
#   - OpenAI:  gpt-4o-mini
#   - Groq:    llama-3.1-8b-instant   (or llama-3.3-70b-versatile)
MODEL_NAME=gpt-4o-mini

# Comma-separated list of allowed origins for CORS. Only needed in deployed
# environments where the frontend and backend live on different domains
# (e.g. "https://ai-real-estate-web.onrender.com"). Defaults to "*" if unset;
# local Docker and Vite dev proxy keep requests same-origin, so this is a no-op there.
ALLOWED_ORIGINS=*
